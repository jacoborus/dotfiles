{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": false
    },
    "docker-mcp": {
      "type": "local",
      "command": [
        "uvx",
        "docker-mcp"
      ],
      "enabled": false
    },
    "cloudflare": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@cloudflare/mcp-server-cloudflare",
        "--url",
        "https://mcp.cloudflare.com/mcp"
      ],
      "enabled": false
    },
    "markitdown": {
      "type": "local",
      "command": [
        "uvx",
        "markitdown-mcp"
      ],
      "enabled": false
    }
  },
  "autoupdate": true,
  "agent": {
    "compaction": {
      "temperature": 0.5
    }
  }
}
